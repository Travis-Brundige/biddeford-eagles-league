# Copy to `.env` for local overrides (never commit `.env`).
# Docker Compose reads variables from the shell or a `.env` file in this directory.

SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Leave POSTGRES_HOST unset for SQLite (local `runserver`).
# Set POSTGRES_HOST=db when using Docker Compose (see compose.yaml).
# POSTGRES_HOST=db
POSTGRES_DB=biddeford
POSTGRES_USER=biddeford
POSTGRES_PASSWORD=biddeford
POSTGRES_PORT=5432
